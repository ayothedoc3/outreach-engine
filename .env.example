# --- core ---
DATABASE_URL=postgres://user:pass@host:5432/outreach
ANTHROPIC_API_KEY=sk-ant-...
OUTREACH_MODEL=claude-opus-4-7

# Master switch. Stays true until your sending domains finish warmup.
# In dry-run nothing is sent; the engine renders every email for review.
DRY_RUN=true

# Gates the dashboard and trigger endpoints (use a long random string).
DASHBOARD_SECRET=change-me-to-a-long-random-string

# --- sender identity / cadence ---
SENDER_NAME=Ayo
SENDER_SIGNATURE=Ayo, ayothedoc.com
BOOKING_LINK=https://calendly.com/ayothedoc/intro
TOUCH_OFFSET_DAYS=0,3,6
DAILY_CAP_PER_MAILBOX=30
SEND_WINDOW_START_HOUR=9
SEND_WINDOW_END_HOUR=17
SEND_TIMEZONE=Europe/Vilnius

# --- mailboxes (JSON list of warmed sending identities) ---
# Leave empty while in DRY_RUN. Example:
# MAILBOXES_JSON=[{"email":"ayo@tryayothedoc.com","smtp_host":"smtp.gmail.com","smtp_port":587,"smtp_user":"ayo@tryayothedoc.com","smtp_pass":"app-password","imap_host":"imap.gmail.com","imap_port":993,"daily_cap":30}]
MAILBOXES_JSON=[]

# --- optional: hand replies to the Lead Engine for an instant booking response ---
LEAD_ENGINE_URL=
LEAD_ENGINE_SECRET=

# --- optional: Apollo sourcing (switch on later) ---
APOLLO_API_KEY=
